{
  "manifest_version": 3,
  "name": "DontWatchTho",
  "version": "1.0",
  "description": "Youtube Shots bocker \"I Don't Watch it Though\"",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
